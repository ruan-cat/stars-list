{
	"name": "@ruan-cat-docs/stars-list",
	"private": true,
	"type": "module",
	"version": "0.0.0",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=22.14.0"
	},
	"author": "ruan-cat",
	"description": "阮喵喵的github star列表，是一个基于工作流自动更新的文档项目。",
	"homepage": "https://ruan-cat.github.io/stars-list",
	"main": "index.js",
	"scripts": {
		"git:fetch": "git fetch -p",
		"git:dev-2-main": "git rebase dev main && git push --follow-tags",
		"git:main-2-dev": "git rebase main dev",
		"up-taze": "pnpm up @ruan-cat/taze-config -L && npx taze -r",
		"format": "prettier --experimental-cli --write '**/*.{js,jsx,ts,tsx,mts,json,css,scss,md,yml,yaml,html}'",
		"prepare": "simple-git-hooks",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"docs:build-in-github-page": "vitepress build docs --base=/stars-list/",
		"build": "pnpm docs:build-in-github-page"
	},
	"devDependencies": {
		"@prettier/plugin-oxc": "^0.1.4",
		"@ruan-cat/commitlint-config": "^4.11.1",
		"@ruan-cat/taze-config": "^1.1.1",
		"@ruan-cat/vitepress-preset-config": "^3.2.1",
		"commitizen": "^4.3.1",
		"commitlint": "^20.5.0",
		"cz-git": "^1.12.0",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.3",
		"prettier-plugin-lint-md": "^1.0.1",
		"simple-git-hooks": "^2.13.1",
		"taze": "^19.11.0",
		"vitepress": "^1.6.4",
		"vitepress-demo-plugin": "^1.5.1",
		"vue": "^3.5.32"
	},
	"keywords": [
		"ruan-cat",
		"github",
		"stars",
		"list"
	],
	"license": "MIT",
	"dependencies": {
		"consola": "^3.4.2"
	}
}
